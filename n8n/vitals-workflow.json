    {
      "parameters": {
        "jsCode": "const body = $input.first().json.body || {};\nconst msg = body.message || {};\nconst calls = msg.toolCalls || msg.toolCallList || [];\nif (!calls.length) throw new Error('triage_symptoms: no toolCalls in payload');\nconst call = calls[0];\nconst args = call?.function?.arguments || {};\nconst toolCallId = call?.id || '';\nconst reportedSymptoms = (args.reported_symptoms || args.reportedSymptoms || '').toString().toLowerCase().trim();\nreturn [{ json: { toolCallId, reportedSymptoms } }];"
      },
      "id": "fb002a7d-c897-4e95-89a4-bdff741ffe06",
      "name": "Extract: triage_symptoms",
