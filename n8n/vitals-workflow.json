      "parameters": {
        "jsCode": "const body = $input.first().json.body || {};\nconst msg = body.message || {};\nconst calls = msg.toolCalls || msg.toolCallList || [];\nif (!calls.length) throw new Error('lookup_patient: no toolCalls in payload');\nconst call = calls[0];\nconst args = call?.function?.arguments || {};\nconst toolCallId = call?.id || '';\nconst phone = (args.phone_number || args.phoneNumber || '').toString().trim();\nconst name = (args.nameOptional || args.name || '').toString().trim();\nreturn [{ json: { toolCallId, phone, name, hasPhone: phone.length > 0 } }];"
