      "id": "88617610-6a33-4f92-bd3d-c8cb14f63037",
      "name": "Google Sheets: Symptoms",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4,
      "position": [
        11312,
        8064
      ],
      "alwaysOutputData": true,
      "credentials": {
        "googleSheetsOAuth2Api": {
          "id": "<GOOGLE_SHEETS_CREDENTIAL_ID>",
          "name": "<GOOGLE_SHEETS_CREDENTIAL_NAME>"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const { toolCallId, reportedSymptoms } = $('Extract: triage_symptoms').first().json;\nconst rows = $input.all().map(i => i.json);\nconst matchedSymptoms = [];\nlet emergencyHit = false;\nlet hasHighRisk = false;\nfor (const r of rows) {\n  const symptomString = (r['Symptoms'] || '').toString().trim();\n  if (!symptomString) continue;\n  const sheetSymptoms = symptomString.toLowerCase().split(',').map(s => s.trim()).filter(s => s.length > 2);\n  if (sheetSymptoms.some(s => reportedSymptoms.includes(s))) {\n    matchedSymptoms.push(symptomString);\n    const emergency = (r['EmergencyTrigger'] ?? '').toString().toLowerCase();\n    if (['true', 'yes', '1'].includes(emergency)) emergencyHit = true;\n    if ((r['Risk'] || '').toString().toLowerCase() === 'high') hasHighRisk = true;\n  }\n}\nlet risk = 'high';\nlet reason = 'No symptom match found; defaulting to high risk.';\nif (matchedSymptoms.length > 0 && emergencyHit) {\n  risk = 'high'; reason = 'Matched emergency-trigger symptom.';\n} else if (matchedSymptoms.length > 0 && hasHighRisk) {\n  risk = 'high'; reason = 'Matched symptom marked high risk in sheet.';\n} else if (matchedSymptoms.length > 0) {\n  risk = 'low'; reason = 'Matched symptom marked low risk in sheet.';\n}\nconst payload = { results: [{ toolCallId, result: { risk, matchedSymptoms, reason } }] };\nreturn [{ json: payload }];"
      },
