    {
      "parameters": {
        "jsCode": "const { toolCallId } = $('Extract: lookup_patient').first().json;\nconst row = $input.first().json;\nconst found = !!(row['Full Name'] && row['Full Name'].toString().trim().length > 0);\nconst result = {\n  found,\n  fullName: row['Full Name'] || '',\n  chronicCondition: row['Chronic Condition'] || '',\n  email: row['Email'] || ''\n};\nconst variables = found ? {\n  full_name: row['Full Name'] || '',\n  email: row['Email'] || '',\n  chronic_condition: row['Chronic Condition'] || '',\n  medical_history: row['Medical History'] || ''\n} : null;\nconst payload = { results: [{ toolCallId, result, ...(variables && { variables }) }] };\nreturn [{ json: payload }];"
      },
