    {
      "parameters": {
        "jsCode": "const body = $input.first().json.body || {};\nconst msg = body.message || {};\nconst calls = msg.toolCalls || msg.toolCallList || [];\nif (!calls.length) throw new Error('force_book_sheet: no toolCalls in payload');\nconst call = calls[0];\nconst args = call?.function?.arguments || {};\nconst toolCallId = call?.id || '';\nconst appointmentTime = (args.appointment_time || args.appointmentTime || '').toString().trim();\nconst datePart = (() => { try { return appointmentTime.includes('T') ? appointmentTime.split('T')[0] : (appointmentTime || 'DATE_MISSING'); } catch(e) { return 'DATE_PARSE_ERROR'; } })();\nconst timePart = (() => { try { return appointmentTime.includes('T') ? appointmentTime.split('T')[1].replace('Z','') : (appointmentTime || 'TIME_MISSING'); } catch(e) { return 'TIME_PARSE_ERROR'; } })();\nreturn [{ json: {\n  toolCallId,\n  appointmentTime,\n  datePart,\n  timePart,\n  fullName: (args.full_name || args.fullName || 'UNKNOWN').toString().trim(),\n  phone: (args.phone_number || args.phoneNumber || '').toString().trim(),\n  reason: (args.reason || '').toString().trim(),\n  risk: (args.risk || '').toString().trim(),\n  notes: (args.notes || '').toString().trim()\n} }];"
      },
