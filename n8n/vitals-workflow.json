    {
      "parameters": {
        "jsCode": "const { toolCallId } = $('Extract: lookup_patient').first().json;\nconst items = $input.all();\nlet rows = items.map(i => i.json).filter(Boolean);\nif (rows.length === 1 && Array.isArray(rows[0].data)) rows = rows[0].data;\nconst validRows = rows.filter(r => r['Full Name'] && r['Full Name'].toString().trim().length > 0);\nlet result, variables = null;\nif (validRows.length === 1) {\n  const d = validRows[0];\n  result = { found: true, fullName: d['Full Name'] || '', chronicCondition: d['Chronic Condition'] || '', email: d['Email'] || '' };\n  variables = { full_name: d['Full Name'] || '', email: d['Email'] || '', chronic_condition: d['Chronic Condition'] || '', medical_history: d['Medical History'] || '' };\n} else if (validRows.length === 0) {\n  result = { found: false, needsPhone: true, reason: 'no matches' };\n} else {\n  result = { found: false, needsPhone: true, reason: 'multiple matches', count: validRows.length };\n}\nconst payload = { results: [{ toolCallId, result, ...(variables && { variables }) }] };\nreturn [{ json: payload }];"
      },
